<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>FIFA 2026 Final</title>
<style>
  body { 
    margin: 0; font-family: 'Segoe UI', sans-serif; 
    background: linear-gradient(135deg, #87CEEB, #FF4500); 
    color: white; text-align: center; min-height: 100vh; 
  }
  
  /* PREMIUM LOCKED CARDS */
  .grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 15px; padding: 20px; }
  .card { 
    width: 150px; height: 200px; background: rgba(255,255,255,0.9); color: black; 
    border: 3px solid gold; border-radius: 15px; display: flex; flex-direction: column; 
    align-items: center; justify-content: center; opacity: 0; transform: scale(0.8);
    transition: all 0.5s ease; font-weight: bold; padding: 5px;
  }
  .card b { color: #FF4500; text-transform: uppercase; }

  .revealed { background: white; color: black; padding: 40px; border-radius: 30px; width: 70%; margin: 30px auto; border: 5px solid gold; }
</style>
</head>
<body>

<audio id="bg-music" src="music.mp3" loop></audio>

<div id="page-1" style="padding:50px;">
  <h1>WELCOME TO FIFA WORLD CUP 2026</h1>
  <button onclick="startApp()" style="padding:20px 40px; font-size:24px;">ENTER</button>
</div>

<div id="page-2" style="display:none; padding:20px;">
  <div style="background:rgba(0,0,0,0.3); padding:20px; display:inline-block; border-radius:15px;">
    <input id="code" placeholder="Secret Code">
    <input id="num" placeholder="Ticket Number or ALL">
    <button onclick="reveal()">REVEAL</button>
  </div>
  <div class="grid" id="grid"></div>
  <div id="stage"></div>
</div>

<script>
  // PASTE YOUR FULL ticketsData ARRAY HERE
  const ticketsData = [ /* ... */ ];
  
  function startApp() {
    document.getElementById('page-1').style.display = 'none';
    document.getElementById('page-2').style.display = 'block';
    document.getElementById('bg-music').play();
    
    const grid = document.getElementById('grid');
    ticketsData.forEach((t, i) => {
      grid.innerHTML += `<div class="card" id="card-${t.id}">Ticket ${t.id}<br>OWNER<br><b>${t.owners}</b></div>`;
    });
    
    // Appear one by one
    let i = 0;
    function showNext() {
      if(i < ticketsData.length) {
        const el = document.getElementById(`card-${ticketsData[i].id}`);
        el.style.opacity = "1";
        el.style.transform = "scale(1)";
        i++;
        setTimeout(showNext, 200); // 200ms gap between each
      }
    }
    showNext();
  }

  function reveal() {
    if(document.getElementById('code').value !== "GOAT VS TIKI TAKA") return alert("Wrong Code!");
    const num = document.getElementById('num').value.toUpperCase();
    
    document.getElementById('grid').style.display = 'none';
    
    if(num === 'ALL') {
      ticketsData.forEach(t => show(t));
    } else {
      const t = ticketsData.find(x => x.id == num);
      if(t) show(t);
    }
  }

  function show(t) {
    document.getElementById('stage').innerHTML += `
      <div class="revealed">
        <h3>Ticket ${t.id} - ${t.owners}</h3>
        <div style="display:flex; justify-content:space-around">
          <div><img src="${t.argentina.photo}" width="120"><p>${t.argentina.name} #${t.argentina.number}</p></div>
          <div><img src="${t.spain.photo}" width="120"><p>${t.spain.name} #${t.spain.number}</p></div>
        </div>
      </div>
    `;
    const msg = new SpeechSynthesisUtterance(`Ticket ${t.id}, owned by ${t.owners}. Argentina, ${t.argentina.name}. Spain, ${t.spain.name}.`);
    window.speechSynthesis.speak(msg);
  }
</script>
</body>
</html>
